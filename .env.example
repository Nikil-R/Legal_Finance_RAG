# ============ Required Settings ============
GROQ_API_KEY=your_groq_api_key_here

# ============ RAG Configuration ============
# GROQ_MODEL options: llama-3.1-8b-instant, llama-3.1-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant
TEMPERATURE=0.0

# Embedding / Re-ranking Models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Parameters
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5

# ============ System Settings ============
CHROMA_PERSIST_DIR=./chroma_db
LOG_LEVEL=INFO
LOG_FORMAT=json
SLOW_REQUEST_THRESHOLD_MS=2000

# ============ API/Frontend Settings ============
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
API_AUTH_ENABLED=true
API_KEYS=replace_with_strong_key_1,replace_with_strong_key_2  # gitleaks:allow
API_KEYS_HASHED=  # gitleaks:allow
API_KEY_MIN_LENGTH=24
API_REQUIRE_KEY_ID=false
API_KEY_HEADER_NAME=x-api-key
API_KEY_ID_HEADER_NAME=x-api-key-id
REJECT_DEFAULT_API_KEYS=true
RATE_LIMIT_RPM=120
REQUEST_TIMEOUT_SECONDS=45

# ============ Runtime / Infra ============
# Optional Redis for distributed rate limit + cache
REDIS_URL=
REDIS_KEY_PREFIX=legal_finance_rag
INGESTION_QUEUE_BACKEND=auto
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
INGESTION_LOCAL_WORKERS=2
INGESTION_JOB_TTL_SECONDS=86400
ENABLE_QUERY_CACHE=true
QUERY_CACHE_TTL_SECONDS=300
LLM_REQUEST_TIMEOUT_SECONDS=40
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.0

# ============ Retrieval / Safety ============
ENABLE_GUARDRAILS=true
ENABLE_QUERY_REWRITE=true
GUARDRAIL_MIN_TOP_SCORE=0.15
GUARDRAIL_MIN_RERANKED_CHUNKS=1
PII_REDACTION_ENABLED=true
USER_DOC_RETENTION_DAYS=30

# ============ Evaluation Gate ============
EVAL_GATE_MIN_PASS_RATE=0.8
EVAL_GATE_MIN_FAITHFULNESS=0.7
EVAL_GATE_MIN_CORRECTNESS=0.6
EVAL_GATE_MIN_CITATION_QUALITY=0.8
EVAL_GATE_MIN_RETRIEVAL_RELEVANCE=0.5
